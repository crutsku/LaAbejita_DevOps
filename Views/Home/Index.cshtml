@model LaAbejita.Models.Inventory

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center justify-content-between mx-auto shadow-sm" role="alert" id="successAlert" style="border-radius: 12px; max-width: 800px;">
        <span>
            <strong>&#10003;</strong> @TempData["SuccessMessage"]
        </span>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="container mb-5 mt-4">
    <div class="d-flex align-items-center">
        <h1 class="mb-0 fw-light fst-italic" style="color: #333; font-size: 2.5rem;">La Abejita 100% natural</h1>
    </div>
</div>

<div class="container mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2 class="fw-bold mb-0" style="font-size: 1.8rem;">Inventario</h2>

        <div class="d-flex gap-2">
            <button type="button" class="btn-platillo-top shadow-sm"
                    style="background-color: #fdd835;"
                    onclick="location.href='@Url.Action("CrearOrden", "Home")'">
                Crear orden
            </button>

            <button id="btnAgregar" class="btn-platillo-top shadow-sm">
                + Platillo
            </button>
        </div>
    </div>
</div>

<div class="container">
    <form asp-action="GetDataPlate" method="post" class="card abeja-card p-4 mb-5 hidden" id="formAgregar">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="abeja-title mb-0">Nuevo Platillo</h3>
            <button type="button" id="btnCerrar" class="btn-close btn-close-abeja shadow-sm"></button>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label fw-bold small">Nombre del platillo</label>
                <input asp-for="NombrePlatillo" class="form-control" placeholder="Ej. Spaguetti" />
            </div>
            <div class="col-md-5 mb-3">
                <label class="form-label fw-bold small">Descripción</label>
                <input asp-for="Descripcion" class="form-control" placeholder="Detalles..." />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label fw-bold small">Precio</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Precio" type="number" step="0.01" class="form-control" placeholder="0.00" />
                </div>
            </div>
        </div>
        <div class="text-end mt-2">
            <button type="submit" class="btn btn-success px-5 fw-bold" style="border-radius: 10px;">
                Guardar Platillo
            </button>
        </div>
    </form>
</div>

<hr class="container my-5" style="opacity: 0.1;" />

<div class="container pb-5">
    <div class="row">
        @if (ViewBag.ListaPlatillos != null)
        {
            foreach (var item in ViewBag.ListaPlatillos)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card platillo-card h-100">
                        <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=400&auto=format&fit=crop" class="card-img-top" alt="platillo">

                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title mb-0 fw-bold">@item.NombrePlatillo</h5>
                                <span class="card-precio fw-normal text-muted">$@item.Precio.ToString("F2")</span>
                            </div>
                            <p class="card-text text-muted small mt-2">
                                @item.Descripcion
                            </p>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">No hay platillos en el inventario.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Mostrar formulario al hacer clic en + Platillo
            $('#btnAgregar').on('click', function() {
                $('#formAgregar').slideDown().removeClass('hidden');
                $(this).fadeOut();
            });

            // Cerrar formulario con la X
            $('#btnCerrar').on('click', function() {
                $('#formAgregar').slideUp(function() {
                    $(this).addClass('hidden');
                });
                $('#btnAgregar').fadeIn();
            });
        });
    </script>
}